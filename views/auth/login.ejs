<html>
  <head>
    <%- include('../header.ejs', { title: title }) %>
  </head>
  <body class="auth-page">
    <div class="auth-card">
      <div class="mb-4">
        <div class="text-uppercase text-muted small mb-2">CRETA Ops</div>
        <h1 class="h3 mb-1">Đăng nhập hệ thống</h1>
        <p class="text-muted mb-0">Truy cập dashboard vận hành và các workspace hóa đơn.</p>
      </div>

      <% if (errorMessage) { %>
        <div class="alert alert-danger"><%= errorMessage %></div>
      <% } %>

      <form method="post" action="/login">
        <div class="form-group">
          <label>Username</label>
          <input type="text" name="username" class="form-control" required autofocus>
        </div>
        <div class="form-group">
          <label>Mật khẩu</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Đăng nhập</button>
      </form>
    </div>
  </body>
</html>
