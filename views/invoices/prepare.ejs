<html>
  <head>
    <%- include('../header.ejs') %>
    <script src="/js/invoice-status.js"></script>
  </head>
  <body>
    <%- include('../menu.ejs') %>
    <div id="prepare-workspace" class="container py-3">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h1>Chuẩn bị đơn</h1>
          <p class="text-muted mb-0">Nhóm việc cho các bước B2, B3, B4.</p>
        </div>
        <a href="/invoices" class="btn btn-outline-secondary">Quay lại danh sách</a>
      </div>

      <div class="row mb-3">
        <div class="col-md-4" v-for="status in prepareStatuses" :key="status.key">
          <div class="card mb-3">
            <div class="card-body">
              <div class="small text-muted">{{ status.key }}</div>
              <h5 class="card-title mb-1">{{ status.title }}</h5>
              <div class="display-4">{{ countByStatus(status.key) }}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-body">
          <div class="form-row align-items-end">
            <div class="col-md-3">
              <label>Trạng thái</label>
              <select class="form-control" v-model="selectedStatusKey">
                <option value="">Tất cả</option>
                <option v-for="status in prepareStatuses" :value="status.key">{{ status.key }} - {{ status.title }}</option>
              </select>
            </div>
            <div class="col-md-4">
              <label>Tìm theo mã / khách</label>
              <input class="form-control" v-model="searchText" placeholder="VD: HD020865 hoặc KH000749">
            </div>
            <div class="col-md-2">
              <button class="btn btn-outline-primary btn-block" @click="refreshAll()">Làm mới</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Mã HĐ</th>
                <th>Khách</th>
                <th>Trạng thái</th>
                <th>Ngày đơn</th>
                <th>Tổng tiền</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="invoice in filteredInvoices" :key="invoice.code">
                <td><a :href="'/invoices/detail?code=' + invoice.code">{{ invoice.code }}</a></td>
                <td>{{ invoice.customerName || invoice.customerCode || '-' }}</td>
                <td>
                  <span class="badge" :class="badgeClass(invoice.status)">
                    {{ statusTitle(invoice.status) }}
                  </span>
                </td>
                <td>{{ formatDate(invoice.purchaseDate) }}</td>
                <td>{{ formatMoney(invoice.total) }}</td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary" @click="changeStatus(invoice, 'B2')">B2</button>
                    <button class="btn btn-outline-warning" @click="changeStatus(invoice, 'B3')">B3</button>
                    <button class="btn btn-outline-info" @click="changeStatus(invoice, 'B4')">B4</button>
                    <a class="btn btn-outline-secondary" :href="'/invoices/detail?code=' + invoice.code">Chi tiết</a>
                  </div>
                </td>
              </tr>
              <tr v-if="filteredInvoices.length === 0">
                <td colspan="6" class="text-center text-muted">Không có đơn phù hợp.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      var PrepareInvoice = Backbone.Model.extend({
        urlRoot: '/api/invoices'
      })

      function normalizeStatusRecord(status) {
        return window.getInvoiceStatusMeta(status)
      }

      new Vue({
        el: '#prepare-workspace',
        data: {
          invoices: [],
          invoiceStates: [],
          selectedStatusKey: '',
          searchText: ''
        },
        computed: {
          prepareStatuses() {
            return window.INVOICE_STATUSES.filter(status => ['B2', 'B3', 'B4'].includes(status.key))
          },
          mergedInvoices() {
            var stateMap = {}
            this.invoiceStates.forEach(function(record) {
              stateMap[record.code] = record
            })
            return this.invoices.map(function(invoice) {
              var local = stateMap[invoice.code] || {}
              return Object.assign({}, invoice, {
                status: local.status || 'B1',
                statusInfo: local.statusInfo || window.getInvoiceStatusMeta(local.status || 'B1')
              })
            })
          },
          filteredInvoices() {
            var search = this.searchText.trim().toLowerCase()
            return this.mergedInvoices.filter(invoice => {
              var inPrepare = ['B2', 'B3', 'B4'].includes(window.normalizeInvoiceStatus(invoice.status))
              if (!inPrepare) {
                return false
              }
              var matchesStatus = !this.selectedStatusKey || window.normalizeInvoiceStatus(invoice.status) === this.selectedStatusKey
              var haystack = [invoice.code, invoice.customerCode, invoice.customerName].join(' ').toLowerCase()
              var matchesSearch = !search || haystack.includes(search)
              return matchesStatus && matchesSearch
            })
          }
        },
        methods: {
          refreshAll() {
            this.loadInvoices()
            this.loadInvoiceStates()
          },
          loadInvoices() {
            $.get('/api/kiot/invoices', data => {
              this.invoices = data || []
            })
          },
          loadInvoiceStates() {
            $.get('/api/invoices', data => {
              this.invoiceStates = data || []
            })
          },
          countByStatus(statusKey) {
            return this.mergedInvoices.filter(invoice => window.normalizeInvoiceStatus(invoice.status) === statusKey).length
          },
          statusTitle(status) {
            return normalizeStatusRecord(status).title
          },
          badgeClass(status) {
            return 'badge-' + normalizeStatusRecord(status).style
          },
          formatDate(value) {
            return value ? moment(value).format('DD/MM/YYYY HH:mm') : '-'
          },
          formatMoney(value) {
            return new Intl.NumberFormat('vi-VN').format(Number(value || 0))
          },
          changeStatus(invoice, statusKey) {
            var payload = { code: invoice.code, status: statusKey }
            var existing = this.invoiceStates.find(record => record.code === invoice.code)
            var request
            if (existing && existing.id) {
              request = $.ajax({ url: '/api/invoices/' + existing.id, method: 'PUT', data: payload })
            } else {
              request = $.ajax({ url: '/api/invoices', method: 'POST', data: payload })
            }
            request.done(() => this.loadInvoiceStates())
          }
        },
        created() {
          var params = new URLSearchParams(window.location.search)
          this.searchText = params.get('code') || ''
          this.refreshAll()
        }
      })
    </script>
  </body>
</html>
