<%- include('../partials/invoice-shell-open.ejs', {
  title: 'Đóng hàng',
  pageTitle: 'Đóng hàng',
  pageSubtitle: 'Theo dõi đơn sẵn sàng đóng và các đơn đã đóng hàng.',
  currentPath: '/invoices/package',
  currentUser: currentUser,
  extraHead: '<script src="/js/invoice-status.js"></script>'
}) %>
    <div id="package-workspace">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h2 class="h4 mb-1">Đóng hàng</h2>
          <p class="text-muted mb-0">Quan sát đơn sẵn sàng đóng, số kiện và tiến độ hoàn tất đóng gói.</p>
        </div>
        <a href="/invoices" class="btn btn-outline-secondary">Quay lại danh sách</a>
      </div>

      <div class="row mb-3">
        <div class="col-md-6" v-for="status in packageStatuses" :key="status.key">
          <div class="card mb-3">
            <div class="card-body">
              <div class="small text-muted">{{ status.key }}</div>
              <h5 class="card-title mb-1">{{ status.title }}</h5>
              <div class="display-4">{{ countByStatus(status.key) }}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="card mb-3">
        <div class="card-body">
          <div class="form-row align-items-end">
            <div class="col-md-4">
              <label>Tìm theo mã / khách</label>
              <input class="form-control" v-model="searchText" placeholder="VD: HD020864 hoặc KH000322">
            </div>
            <div class="col-md-2">
              <button class="btn btn-outline-primary btn-block" @click="refreshAll()">Làm mới</button>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>Mã HĐ</th>
                <th>Khách</th>
                <th>Trạng thái</th>
                <th>Số kiện</th>
                <th>Tổng tiền</th>
                <th>Thao tác</th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="invoice in filteredInvoices" :key="invoice.code">
                <td><a :href="'/invoices/detail?code=' + invoice.code">{{ invoice.code }}</a></td>
                <td>{{ invoice.customerName || invoice.customerCode || '-' }}</td>
                <td><span class="badge" :class="badgeClass(invoice.status)">{{ statusTitle(invoice.status) }}</span></td>
                <td>{{ packageCount(invoice) }}</td>
                <td>{{ formatMoney(invoice.total) }}</td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary" disabled title="Sẽ thay bằng action xác nhận đóng hàng có log">Xác nhận đóng hàng</button>
                    <a class="btn btn-outline-secondary" :href="'/invoices/detail?code=' + invoice.code">Chi tiết</a>
                  </div>
                </td>
              </tr>
              <tr v-if="filteredInvoices.length === 0">
                <td colspan="6" class="text-center text-muted">Không có đơn phù hợp.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      function normalizePackageStatus(status) {
        return window.getInvoiceStatusMeta(status)
      }

      new Vue({
        el: '#package-workspace',
        data: {
          invoices: [],
          invoiceStates: [],
          searchText: ''
        },
        computed: {
          packageStatuses() {
            return window.INVOICE_STATUSES.filter(status => ['B4', 'B5'].includes(status.key))
          },
          mergedInvoices() {
            var stateMap = {}
            this.invoiceStates.forEach(function(record) {
              stateMap[record.code] = record
            })
            return this.invoices.map(function(invoice) {
              var local = stateMap[invoice.code] || {}
              return Object.assign({}, invoice, {
                status: local.status || 'B1',
                statusInfo: local.statusInfo || window.getInvoiceStatusMeta(local.status || 'B1'),
                notes: local.notes || []
              })
            })
          },
          filteredInvoices() {
            var search = this.searchText.trim().toLowerCase()
            return this.mergedInvoices.filter(invoice => {
              var statusKey = window.normalizeInvoiceStatus(invoice.status)
              if (!['B4', 'B5'].includes(statusKey)) {
                return false
              }
              var haystack = [invoice.code, invoice.customerCode, invoice.customerName].join(' ').toLowerCase()
              return !search || haystack.includes(search)
            })
          }
        },
        methods: {
          refreshAll() {
            $.get('/api/kiot/invoices', data => {
              this.invoices = data || []
            })
            $.get('/api/invoices', data => {
              this.invoiceStates = data || []
            })
          },
          countByStatus(statusKey) {
            return this.mergedInvoices.filter(invoice => window.normalizeInvoiceStatus(invoice.status) === statusKey).length
          },
          statusTitle(status) {
            return normalizePackageStatus(status).title
          },
          badgeClass(status) {
            return 'badge-' + normalizePackageStatus(status).style
          },
          formatMoney(value) {
            return new Intl.NumberFormat('vi-VN').format(Number(value || 0))
          },
          packageCount(invoice) {
            var result = 0
            ;(invoice.notes || []).forEach(function(note) {
              if (note.type === 'SO_KIEN_HANG') {
                result = note.value
              }
            })
            return result || '-'
          },
        },
        created() {
          var params = new URLSearchParams(window.location.search)
          this.searchText = params.get('code') || ''
          this.refreshAll()
        }
      })
    </script>
<%- include('../partials/invoice-shell-close.ejs') %>
