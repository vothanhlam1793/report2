<%- include('../partials/invoice-shell-open.ejs', {
  title: 'Chi tiết hóa đơn',
  pageTitle: 'Chi tiết hóa đơn',
  pageSubtitle: 'Hồ sơ vận hành theo referenceCode, gom toàn bộ thông tin liên đới của đơn qua các bước xử lý.',
  currentPath: '/invoices',
  currentUser: currentUser,
  extraHead: '<script src="/js/invoice-status.js"></script>'
}) %>
<div id="invoice-detail-page">
  <div class="app-loading app-loading-card" v-if="isLoading">
    <div class="spinner-border text-primary" role="status"></div>
    <div>Đang tải hồ sơ đơn hàng...</div>
  </div>

  <template v-if="!isLoading && currentInvoice.code">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <div class="app-step-chip">Reference trung tâm | Tổng hợp B1 -> B9</div>
        <h2 class="h4 mb-1">{{ currentInvoice.code }}</h2>
        <div class="text-muted">Mã tham chiếu: {{ detail.referenceCode }}</div>
      </div>
      <div class="btn-group">
        <a class="btn btn-outline-dark" :href="'/invoices/warehouse-check?code=' + currentInvoice.code">Phiếu kho</a>
        <a class="btn btn-outline-secondary" :href="'/invoices/prepare?code=' + currentInvoice.code">Cần duyệt kho</a>
        <a class="btn btn-outline-secondary" href="/invoices/dashboard">Dashboard</a>
      </div>
    </div>

    <div class="alert alert-warning" v-if="invoiceState.changeWarningSummary">
      <div class="font-weight-bold">Cảnh báo thay đổi đơn</div>
      <div>{{ invoiceState.changeWarningSummary }}</div>
    </div>

    <div class="row mb-3">
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-muted">Trạng thái hiện tại</div>
            <div class="mt-2"><span class="badge" :class="invoiceBadgeClass(invoiceState.status)">{{ invoiceStatusLabel(invoiceState.status) }}</span></div>
            <div class="small text-muted mt-3">Khách hàng</div>
            <div>{{ currentInvoice.customerName || currentInvoice.customerCode || '-' }}</div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-muted">Ngày đơn</div>
            <div class="mt-2">{{ formatDate(currentInvoice.purchaseDate) }}</div>
            <div class="small text-muted mt-3">Tổng tiền</div>
            <div>{{ formatMoney(currentInvoice.total) }}</div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-muted">Warehouse Check mới nhất</div>
            <div class="mt-2"><span class="badge" :class="whcBadgeClass(latestWarehouseCheck.status)">{{ whcStatusTitle(latestWarehouseCheck.status) }}</span></div>
            <div class="small text-muted mt-3">Kết luận kho</div>
            <div>{{ conclusionTitle(latestWarehouseCheck.stockConclusion) }}</div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="small text-muted">Thông tin liên đới</div>
            <div class="mt-2">{{ relatedInvoices.length }} version đơn</div>
            <div>{{ detail.invoiceEvents.length }} log xử lý</div>
            <div>{{ packageCountLabel() }} kiện hàng</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-lg-4 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Các version liên quan</h5>
            <div class="list-group list-group-flush" v-if="relatedInvoices.length">
              <a
                class="list-group-item list-group-item-action"
                v-for="invoice in relatedInvoices"
                :key="invoice.code"
                :href="'/invoices/detail?code=' + invoice.code"
              >
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <div class="font-weight-bold">{{ invoice.code }}</div>
                    <div class="small text-muted">{{ invoice.customerName || invoice.customerCode || '-' }}</div>
                  </div>
                  <span class="badge" :class="invoiceBadgeClass(invoice.localStatus)">{{ invoiceStatusLabel(invoice.localStatus) }}</span>
                </div>
              </a>
            </div>
            <div class="text-muted" v-else>Chưa có version liên quan.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-8 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Timeline xử lý</h5>
            <div v-if="detail.invoiceEvents.length">
              <div class="border rounded p-3 mb-2" v-for="event in detail.invoiceEvents" :key="event.id">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <div class="font-weight-bold">{{ eventTitle(event) }}</div>
                    <div class="text-muted">{{ event.summary || 'Không có mô tả' }}</div>
                  </div>
                  <span class="badge" :class="eventBadgeClass(event)">{{ eventStatusLabel(event) }}</span>
                </div>
                <div class="small text-muted mt-2">{{ formatEventMeta(event) }}</div>
                <div class="small mt-2" v-if="eventExtraText(event)">{{ eventExtraText(event) }}</div>
              </div>
            </div>
            <div class="text-muted" v-else>Chưa có timeline xử lý cho reference này.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Warehouse Check</h5>
            <div v-if="detail.warehouseChecks.length">
              <div class="border rounded p-3 mb-2" v-for="check in detail.warehouseChecks" :key="check.id">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <div class="font-weight-bold">{{ check.invoiceCode }}</div>
                    <div class="text-muted">{{ check.summary || 'Không có tóm tắt' }}</div>
                  </div>
                  <div class="text-right">
                    <span class="badge mr-1" :class="whcBadgeClass(check.status)">{{ whcStatusTitle(check.status) }}</span>
                    <span class="badge" :class="conclusionBadgeClass(check.stockConclusion)">{{ conclusionTitle(check.stockConclusion) }}</span>
                  </div>
                </div>
                <div class="small text-muted mt-2">
                  Tạo bởi {{ check.createdByName || check.createdByUsername || 'Hệ thống' }} | cập nhật {{ formatDate(check.updatedAt) }}
                </div>
                <a class="btn btn-sm btn-outline-secondary mt-2" :href="'/invoices/warehouse-check?code=' + check.invoiceCode">Mở phiếu</a>
              </div>
            </div>
            <div class="text-muted" v-else>Chưa có warehouse check.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Thiếu hàng và quyết định tiếp theo</h5>
            <div v-if="latestWarehouseCheck.id">
              <div class="mb-2"><strong>Decision status:</strong> {{ decisionTitle(latestWarehouseCheck.decisionStatus) }}</div>
              <div class="mb-2"><strong>Sale decision:</strong> {{ saleDecisionTitle(latestWarehouseCheck.saleDecision) }}</div>
              <div class="mb-2"><strong>Summary:</strong> {{ latestWarehouseCheck.summary || '-' }}</div>
              <div class="text-muted small">Reviewed by {{ latestWarehouseCheck.reviewedByName || latestWarehouseCheck.reviewedByUsername || '-' }}</div>
            </div>
            <div class="text-muted" v-else>Chưa có dữ liệu thiếu hàng.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Phiếu đặt hàng nhanh</h5>
            <div v-if="detail.quickPurchaseRequests.length">
              <div class="border rounded p-3 mb-2" v-for="item in detail.quickPurchaseRequests" :key="item.id">
                <div class="font-weight-bold">{{ item.summary || 'Phiếu đặt hàng nhanh' }}</div>
                <div class="small text-muted">{{ formatDate(item.createdAt) }} | {{ item.createdByName || item.createdByUsername || '-' }}</div>
                <div class="small mt-1">{{ item.items ? item.items.length : 0 }} mã sản phẩm</div>
              </div>
            </div>
            <div class="text-muted" v-else>Chưa có phiếu đặt hàng nhanh.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Phiếu nhập hàng nhanh</h5>
            <div v-if="detail.quickStockReceipts.length">
              <div class="border rounded p-3 mb-2" v-for="item in detail.quickStockReceipts" :key="item.id">
                <div class="font-weight-bold">{{ item.summary || 'Phiếu nhập hàng nhanh' }}</div>
                <div class="small text-muted">{{ formatDate(item.createdAt) }} | {{ item.createdByName || item.createdByUsername || '-' }}</div>
                <div class="small mt-1">{{ item.items ? item.items.length : 0 }} mã sản phẩm</div>
              </div>
            </div>
            <div class="text-muted" v-else>Chưa có phiếu nhập hàng nhanh.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Đóng hàng và giao vận</h5>
            <div class="mb-2"><strong>Số kiện:</strong> {{ packageCountLabel() }}</div>
            <div class="mb-2"><strong>Phiếu / ứng ship:</strong> {{ detail.phieus.length }}</div>
            <div v-if="detail.phieus.length">
              <div class="border rounded p-3 mb-2" v-for="item in detail.phieus" :key="item.id">
                <div class="font-weight-bold">{{ item.type || 'Phiếu giao vận' }}</div>
                <div class="small text-muted">{{ formatDate(item.implementationDate || item.createdAt) }} | {{ item.executorName || item.executorCode || '-' }}</div>
                <div class="small mt-1">{{ item.description || '-' }}</div>
              </div>
            </div>
            <div class="text-muted" v-else>Chưa có phiếu giao vận liên quan trên mã đơn hiện tại.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-6 mb-3">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <h5 class="mb-3">Thông tin nội bộ</h5>
            <div class="mb-2"><strong>Latest WHC ID:</strong> {{ invoiceState.latestWarehouseCheckId || '-' }}</div>
            <div class="mb-2"><strong>Related codes local:</strong> {{ (invoiceState.relatedInvoiceCodes || []).join(', ') || '-' }}</div>
            <div class="mb-2"><strong>Notes:</strong> {{ (invoiceState.notes || []).length }}</div>
            <div class="mb-2"><strong>Actions:</strong> {{ (invoiceState.actions || []).length }}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0">Chi phí phát sinh quy trình</h5>
          <a class="btn btn-sm btn-outline-secondary" :href="'/finance?search=' + encodeURIComponent(detail.referenceCode || currentInvoice.code || '')">Mở Finance</a>
        </div>
        <div class="row mb-3">
          <div class="col-md-4">
            <div class="small text-muted">Tổng chi</div>
            <div class="h5 text-danger">{{ formatMoney(totalOperationalExpense()) }}</div>
          </div>
          <div class="col-md-4">
            <div class="small text-muted">Tổng thu</div>
            <div class="h5 text-success">{{ formatMoney(totalOperationalIncome()) }}</div>
          </div>
          <div class="col-md-4">
            <div class="small text-muted">Số khoản</div>
            <div class="h5">{{ detail.transactions.length }}</div>
          </div>
        </div>
        <div v-if="detail.transactions.length">
          <div class="border rounded p-3 mb-2" v-for="item in detail.transactions" :key="item.id">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <div class="font-weight-bold">{{ transactionCategoryTitle(item.category) }}</div>
                <div class="text-muted">{{ item.description || item.content || '-' }}</div>
              </div>
              <div :class="item.direction === 'income' ? 'text-success font-weight-bold' : 'text-danger font-weight-bold'">{{ formatMoney(item.amount) }}</div>
            </div>
            <div class="small text-muted mt-2">{{ formatDate(item.transactionDate || item.date) }} | {{ transactionCounterpartyLabel(item) }} | {{ item.staffName || item.staffUsername || '-' }}</div>
          </div>
        </div>
        <div class="text-muted" v-else>Chưa có chi phí phát sinh quy trình cho reference này.</div>
      </div>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="mb-3">Sản phẩm của đơn hiện tại</h5>
        <table class="table table-bordered table-hover mb-0">
          <thead>
            <tr>
              <th>Mã SP</th>
              <th>Tên sản phẩm</th>
              <th>Số lượng</th>
              <th>Đơn giá</th>
              <th>Thành tiền</th>
            </tr>
          </thead>
          <tbody>
            <tr v-for="product in currentInvoice.invoiceDetails" :key="product.id || product.productCode">
              <td>{{ product.productCode || '-' }}</td>
              <td>{{ product.productName || '-' }}</td>
              <td>{{ product.quantity || 0 }}</td>
              <td>{{ formatMoney(product.price) }}</td>
              <td>{{ formatMoney(product.subTotal) }}</td>
            </tr>
            <tr v-if="!currentInvoice.invoiceDetails || currentInvoice.invoiceDetails.length === 0">
              <td colspan="5" class="text-center text-muted">Không có sản phẩm.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </template>

  <div class="alert alert-warning" v-if="!isLoading && !currentInvoice.code">
    Không tìm thấy dữ liệu hóa đơn theo mã đã chọn.
  </div>
</div>

<script>
  new Vue({
    el: '#invoice-detail-page',
    data: {
      detail: {
        referenceCode: '',
        currentInvoice: {},
        invoiceState: {},
        relatedInvoices: [],
        warehouseChecks: [],
        latestWarehouseCheck: {},
        invoiceEvents: [],
        quickPurchaseRequests: [],
        quickStockReceipts: [],
        transactions: [],
        phieus: [],
        packageCount: 0
      },
      isLoading: false
    },
    computed: {
      currentInvoice() {
        return this.detail.currentInvoice || {}
      },
      invoiceState() {
        return this.detail.invoiceState || {}
      },
      latestWarehouseCheck() {
        return this.detail.latestWarehouseCheck || {}
      },
      relatedInvoices() {
        return this.detail.relatedInvoices || []
      }
    },
    methods: {
      loadData() {
        var params = new URLSearchParams(window.location.search)
        var code = params.get('code') || ''
        if (!code) {
          return
        }
        this.isLoading = true
        $.get('/api/invoices/detail/' + code, data => {
          this.detail = Object.assign({}, this.detail, data || {})
        }).always(() => {
          this.isLoading = false
        })
      },
      invoiceStatusTitle(status) {
        return window.getInvoiceStatusMeta(status).title
      },
      invoiceStatusLabel(status) {
        var meta = window.getInvoiceStatusMeta(status)
        return meta.key + ' - ' + meta.title
      },
      invoiceBadgeClass(status) {
        return 'badge-' + window.getInvoiceStatusMeta(status).style
      },
      whcStatusTitle(status) {
        var map = {
          draft: 'Draft',
          checking: 'Đang kiểm tra',
          completed: 'Đã hoàn tất'
        }
        return map[status] || status || 'Draft'
      },
      whcBadgeClass(status) {
        var map = {
          draft: 'badge-secondary',
          checking: 'badge-warning',
          completed: 'badge-success'
        }
        return map[status] || 'badge-light'
      },
      conclusionTitle(value) {
        var map = {
          enough: 'Đủ hàng',
          shortage: 'Thiếu hàng'
        }
        return map[value] || 'Chưa kết luận'
      },
      conclusionBadgeClass(value) {
        var map = {
          enough: 'badge-success',
          shortage: 'badge-danger'
        }
        return map[value] || 'badge-light'
      },
      decisionTitle(status) {
        var map = {
          pending_stock_review: 'Chờ kho kiểm tra',
          pending_sale_decision: 'Chờ Sale quyết định',
          purchase_selected: 'Đã chọn đặt hàng',
          change_order_selected: 'Đã chọn đổi đơn',
          done: 'Đã hoàn tất'
        }
        return map[status] || status || '-'
      },
      saleDecisionTitle(value) {
        var map = {
          purchase_more: 'Đặt hàng thêm',
          change_order: 'Đổi đơn'
        }
        return map[value] || '-'
      },
      eventTitle(event) {
        var eventTypeMap = {
          warehouse_check_created: 'Tạo phiếu kiểm tra kho',
          warehouse_check_refreshed: 'Làm mới phiếu kiểm tra kho',
          warehouse_check_completed: 'Hoàn tất phiếu kiểm tra kho',
          warehouse_check_confirmed: 'Xác nhận đủ hàng',
          warehouse_check_shortage_detected: 'Kết luận thiếu hàng',
          sale_decision_purchase_more: 'Sale chọn đặt hàng thêm',
          sale_decision_change_order: 'Sale chọn đổi đơn',
          quick_purchase_created: 'Tạo phiếu đặt hàng nhanh',
          quick_stock_receipt_created: 'Tạo phiếu nhập hàng nhanh',
          auto_closed_legacy_invoice: 'Tự động đóng dữ liệu cũ'
        }
        return eventTypeMap[event.eventType] || event.eventType || 'Sự kiện xử lý'
      },
      eventStatusLabel(event) {
        if (event.fromStatus && event.toStatus) {
          return event.fromStatus + ' -> ' + event.toStatus
        }
        if (event.toStatus) {
          return event.toStatus
        }
        return 'Log'
      },
      eventBadgeClass(event) {
        if (event.toStatus === 'B10') {
          return 'badge-dark'
        }
        if (event.toStatus === 'B2' || event.eventType === 'warehouse_check_completed') {
          return 'badge-success'
        }
        if (event.toStatus === 'B3') {
          return 'badge-warning'
        }
        if (event.toStatus === 'B4' || event.toStatus === 'B5') {
          return 'badge-primary'
        }
        return 'badge-secondary'
      },
      formatEventMeta(event) {
        var actor = event.actorName || event.actorUsername || event.actorRole || 'Hệ thống'
        var time = event.createdAt ? moment(event.createdAt).format('DD/MM/YYYY HH:mm') : '-'
        var invoiceCode = event.invoiceCode || '-'
        return actor + ' | ' + time + ' | ' + invoiceCode
      },
      eventExtraText(event) {
        var payload = event.payload || {}
        if (payload.replacementInvoiceCode) {
          return 'Đơn thay thế: ' + payload.replacementInvoiceCode
        }
        if (typeof payload.shortageCount === 'number') {
          return 'Số mã đang thiếu: ' + payload.shortageCount
        }
        if (typeof payload.itemCount === 'number') {
          return 'Số dòng liên quan: ' + payload.itemCount
        }
        if (payload.relatedInvoiceCodes && payload.relatedInvoiceCodes.length) {
          return 'Các version liên quan: ' + payload.relatedInvoiceCodes.join(', ')
        }
        return ''
      },
      formatDate(value) {
        return value ? moment(value).format('DD/MM/YYYY HH:mm') : '-'
      },
      formatMoney(value) {
        return new Intl.NumberFormat('vi-VN').format(Number(value || 0))
      },
      totalOperationalExpense() {
        return (this.detail.transactions || []).filter(function (item) {
          return item.direction !== 'income'
        }).reduce(function (sum, item) {
          return sum + Number(item.amount || 0)
        }, 0)
      },
      totalOperationalIncome() {
        return (this.detail.transactions || []).filter(function (item) {
          return item.direction === 'income'
        }).reduce(function (sum, item) {
          return sum + Number(item.amount || 0)
        }, 0)
      },
      transactionCategoryTitle(category) {
        var map = {
          inbound_shipping_fee: 'Phí chuyển hàng về',
          return_shipping_fee: 'Phí trả hàng',
          packing_cost: 'Phí đóng gói',
          loading_cost: 'Phí bốc xếp',
          other_operational: 'Chi phí khác'
        }
        return map[category] || (category || '-')
      },
      transactionCounterpartyLabel(item) {
        return [item.counterpartyType || '-', item.counterpartyName || '-'].join(' | ')
      },
      packageCountLabel() {
        return this.detail.packageCount || 0
      }
    },
    created() {
      this.loadData()
    }
  })
</script>
<%- include('../partials/invoice-shell-close.ejs') %>
